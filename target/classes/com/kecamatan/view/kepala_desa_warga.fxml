<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.kecamatan.controller.KepalaDesaWargaController"
            stylesheets="@../style/style.css" styleClass="dashboard-container">

    <left>
        <VBox spacing="10" styleClass="sidebar">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            
            <!-- Clock Widget -->
            <VBox alignment="CENTER" spacing="5" styleClass="clock-container">
                <Text fx:id="clockTimeText" text="00:00:00" styleClass="clock-time"/>
                <Text fx:id="clockDateText" text="Senin, 01 Januari" styleClass="clock-date"/>
            </VBox>

            <Text text="MENU" styleClass="sidebar-title"/>
            <Button fx:id="btnProfil" text="Profil Saya" onAction="#goToProfil" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Button fx:id="btnKepalaDesa" text="Data Kepala Desa" maxWidth="Infinity" styleClass="sidebar-button-active"/>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox spacing="10" alignment="CENTER" styleClass="user-info-pane">
                <padding>
                    <Insets bottom="10"/>
                </padding>
                <Label fx:id="userNameLabel" text="User Name" styleClass="user-name-text"/>
                <Label fx:id="userRoleLabel" text="ROLE" styleClass="role-badge-warga"/>
            </HBox>
            <Button text="Logout" onAction="#handleLogout" maxWidth="Infinity" styleClass="logout-button"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="20">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Data Kepala Desa Siwalanpanji" styleClass="title-text"/>
            </HBox>

            <VBox spacing="10" VBox.vgrow="ALWAYS" styleClass="card">
                <TableView fx:id="kepalaDesaTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNama" text="Nama Kepala Desa" prefWidth="250"/>
                        <TableColumn fx:id="colDesa" text="Desa" prefWidth="130"/>
                        <TableColumn fx:id="colNoTelp" text="No Telp" prefWidth="120"/>
                        <TableColumn fx:id="colMulai" text="Periode Mulai" prefWidth="120"/>
                        <TableColumn fx:id="colSelesai" text="Periode Selesai" prefWidth="130"/>
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>
