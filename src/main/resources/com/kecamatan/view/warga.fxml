<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.kecamatan.controller.WargaController"
            stylesheets="@../style/style.css" styleClass="dashboard-container">
    
    <left>
        <VBox spacing="10" styleClass="sidebar">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Text text="MENU" styleClass="sidebar-title"/>
            <Button fx:id="btnDashboard" text="Dashboard" onAction="#goToDashboard" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Button fx:id="btnDesa" text="Data Desa" onAction="#goToDesa" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Button fx:id="btnKepalaDesa" text="Data Kepala Desa" onAction="#goToKepalaDesa" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Button fx:id="btnWarga" text="Data Warga" maxWidth="Infinity" styleClass="sidebar-button-active"/>
            <Button fx:id="btnLaporan" text="Statistik" onAction="#goToLaporan" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Button fx:id="btnProfil" text="Profil Saya" onAction="#goToProfil" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox spacing="10" alignment="CENTER" styleClass="user-info-pane">
                <padding>
                    <Insets bottom="10"/>
                </padding>
                <Label fx:id="userNameLabel" text="User Name" styleClass="user-name-text"/>
                <Label fx:id="userRoleLabel" text="ROLE" styleClass="role-badge-admin"/>
            </HBox>
            <Button text="Logout" onAction="#handleLogout" maxWidth="Infinity" styleClass="logout-button"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="20">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            

            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="Data Warga / Penduduk" styleClass="title-text"/>
                <TextField fx:id="searchField" promptText="Cari NIK atau Nama..." HBox.hgrow="ALWAYS" styleClass="search-field"/>
                <Label text="Desa:" styleClass="filter-label"/>
                <ComboBox fx:id="filterDesaComboBox" prefWidth="180" styleClass="filter-combobox" promptText="Semua Desa"/>
                <Button onAction="#handleResetFilter" styleClass="reset-filter-button" text="Reset">
                    <tooltip>
                        <Tooltip text="Reset Filter"/>
                    </tooltip>
                </Button>
            </HBox>

            <HBox spacing="20" VBox.vgrow="ALWAYS">
                <!-- Data Table -->
                <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="card">
                    <Text text="Tabel Data Warga" styleClass="card-title"/>
                    <TableView fx:id="wargaTable" VBox.vgrow="ALWAYS">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colNik" text="NIK" prefWidth="140"/>
                            <TableColumn fx:id="colNama" text="Nama Lengkap" prefWidth="180"/>
                            <TableColumn fx:id="colJenkel" text="L/P" prefWidth="60"/>
                            <TableColumn fx:id="colAgama" text="Agama" prefWidth="80"/>
                            <TableColumn fx:id="colStatusKawin" text="Status Kawin" prefWidth="100"/>
                            <TableColumn fx:id="colPekerjaan" text="Pekerjaan" prefWidth="120"/>
                            <TableColumn fx:id="colNoHp" text="No HP" prefWidth="100"/>
                            <TableColumn fx:id="colTglLahir" text="Tgl Lahir" prefWidth="90"/>
                            <TableColumn fx:id="colDesa" text="Desa" prefWidth="110"/>
                            <TableColumn fx:id="colKecamatan" text="Kecamatan" prefWidth="120"/>
                            <TableColumn fx:id="colAlamat" text="Alamat" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>

                <!-- Input Form -->
                <VBox spacing="15" prefWidth="300" styleClass="card" maxHeight="Infinity">
                    <Text text="Form Data Warga" styleClass="card-title"/>
                    
                    <VBox spacing="5">
                        <Label text="NIK" styleClass="input-label"/>
                        <TextField fx:id="nikField" promptText="Masukkan 16 Digit" styleClass="input-field"/>
                    </VBox>
                    
                    <VBox spacing="5">
                        <Label text="Nama Lengkap" styleClass="input-label"/>
                        <TextField fx:id="namaField" styleClass="input-field"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Tanggal Lahir" styleClass="input-label"/>
                        <DatePicker fx:id="tglLahirPicker" maxWidth="Infinity" styleClass="input-field"/>
                    </VBox>

                    <HBox spacing="10">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Jenis Kelamin" styleClass="input-label"/>
                            <ComboBox fx:id="jenkelComboBox" maxWidth="Infinity" styleClass="input-field">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="Laki-laki"/>
                                        <String fx:value="Perempuan"/>
                                    </FXCollections>
                                </items>
                            </ComboBox>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Pilih Desa" styleClass="input-label"/>
                            <ComboBox fx:id="desaComboBox" maxWidth="Infinity" styleClass="input-field"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="10">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Agama" styleClass="input-label"/>
                            <ComboBox fx:id="agamaComboBox" maxWidth="Infinity" styleClass="input-field">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="Islam"/>
                                        <String fx:value="Kristen"/>
                                        <String fx:value="Katolik"/>
                                        <String fx:value="Hindu"/>
                                        <String fx:value="Buddha"/>
                                        <String fx:value="Khonghucu"/>
                                    </FXCollections>
                                </items>
                            </ComboBox>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Status Kawin" styleClass="input-label"/>
                            <ComboBox fx:id="statusKawinComboBox" maxWidth="Infinity" styleClass="input-field">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="Belum Kawin"/>
                                        <String fx:value="Kawin"/>
                                        <String fx:value="Cerai Hidup"/>
                                        <String fx:value="Cerai Mati"/>
                                    </FXCollections>
                                </items>
                            </ComboBox>
                        </VBox>
                    </HBox>

                    <HBox spacing="10">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Pekerjaan" styleClass="input-label"/>
                            <TextField fx:id="pekerjaanField" promptText="Masukkan Pekerjaan" styleClass="input-field"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="No HP" styleClass="input-label"/>
                            <TextField fx:id="noHpField" promptText="Masukkan No HP" styleClass="input-field"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="10">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Pilih RW" styleClass="input-label"/>
                            <ComboBox fx:id="rwComboBox" maxWidth="Infinity" styleClass="input-field" HBox.hgrow="ALWAYS"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Pilih RT" styleClass="input-label"/>
                            <ComboBox fx:id="rtComboBox" maxWidth="Infinity" styleClass="input-field" HBox.hgrow="ALWAYS"/>
                        </VBox>
                    </HBox>
                    
                    <VBox spacing="5">
                        <Label text="Alamat" styleClass="input-label"/>
                        <TextArea fx:id="alamatArea" prefHeight="80" wrapText="true" styleClass="input-field"/>
                    </VBox>

                    <HBox spacing="10">
                        <Button text="Simpan" onAction="#handleSave" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="login-button"/>
                        <Button text="Hapus" onAction="#handleDelete" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="logout-button"/>
                        <Button onAction="#handleReset" styleClass="reset-icon-button" text="↻">
                            <tooltip>
                                <Tooltip text="Reset Form"/>
                            </tooltip>
                        </Button>
                    </HBox>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
