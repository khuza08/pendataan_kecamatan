<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.kecamatan.controller.ProfilController"
            stylesheets="@../style/style.css" styleClass="dashboard-container">
    
    <left>
        <VBox spacing="10" styleClass="sidebar">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Text text="MENU" styleClass="sidebar-title"/>
            <Button fx:id="btnDashboard" text="Dashboard" onAction="#goToDashboard" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Button fx:id="btnDesa" text="Data Desa" onAction="#goToDesa" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Button fx:id="btnWarga" text="Data Warga" onAction="#goToWarga" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Button fx:id="btnLaporan" text="Statistik" onAction="#goToLaporan" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Button text="Profil Saya" maxWidth="Infinity" styleClass="sidebar-button-active"/>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox spacing="10" alignment="CENTER" styleClass="user-info-pane">
                <padding>
                    <Insets bottom="10"/>
                </padding>
                <Label fx:id="userNameLabel" text="User Name" styleClass="user-name-text"/>
                <Label fx:id="userRoleLabel" text="ROLE" styleClass="role-badge-admin"/>
            </HBox>
            <Button text="Logout" onAction="#handleLogout" maxWidth="Infinity" styleClass="logout-button"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="20">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Profil Saya" styleClass="title-text"/>
            </HBox>

            <HBox spacing="20" maxWidth="Infinity">

                <!-- Data Pribadi -->
                <VBox spacing="15" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="Data Pribadi" styleClass="card-title"/>
                    <GridPane hgap="20" vgap="15">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="140" />
                            <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>

                        <Label text="NIK" styleClass="input-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="nikField" editable="false" styleClass="input-field" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Nama Lengkap" styleClass="input-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="namaField" editable="false" styleClass="input-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Jenis Kelamin" styleClass="input-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="jenkelField" editable="false" styleClass="input-field" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Tanggal Lahir" styleClass="input-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <TextField fx:id="tglLahirField" editable="false" styleClass="input-field" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                        <Label text="Agama" styleClass="input-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <TextField fx:id="agamaField" editable="false" styleClass="input-field" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                        <Label text="Status Kawin" styleClass="input-label" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                        <TextField fx:id="statusKawinField" editable="false" styleClass="input-field" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                        <Label text="Pekerjaan" styleClass="input-label" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                        <TextField fx:id="pekerjaanField" editable="false" styleClass="input-field" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                        <Label text="No HP" styleClass="input-label" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                        <TextField fx:id="noHpField" editable="false" styleClass="input-field" GridPane.rowIndex="7" GridPane.columnIndex="1"/>
                    </GridPane>
                </VBox>

                <!-- Alamat / Kecamatan -->
                <VBox spacing="15" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="Alamat / Kecamatan" styleClass="card-title"/>
                    <GridPane hgap="20" vgap="15">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="140" />
                            <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>

                        <Label text="Alamat" styleClass="input-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextArea fx:id="alamatArea" editable="false" prefHeight="80" wrapText="true" styleClass="input-field" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Desa" styleClass="input-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="desaField" editable="false" styleClass="input-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Kecamatan" styleClass="input-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="kecamatanField" editable="false" styleClass="input-field" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="RT / RW" styleClass="input-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <TextField fx:id="rtrwField" editable="false" styleClass="input-field" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                    </GridPane>
                </VBox>
            </HBox>

            <Text text="* Hubungi Admin jika ada kesalahan data" styleClass="subtitle-text" style="-fx-font-style: italic;"/>
        </VBox>
    </center>
</BorderPane>
